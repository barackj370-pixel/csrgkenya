generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String?
  role      String   @default("MOBILIZER")
  wardId    String?
  createdAt DateTime @default(now())
}

model Ward {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  description String?
  issues      Issue[]
  discussions Discussion[]
  groups      Group[]
  createdAt   DateTime     @default(now())
}

model Issue {
  id          String   @id @default(uuid())
  title       String
  description String
  wardId      String
  ward        Ward     @relation(fields: [wardId], references: [id])
  votes       Int      @default(0)
  createdAt   DateTime @default(now())
}

model Discussion {
  id          String   @id @default(uuid())
  title       String
  description String
  date        DateTime
  status      String   @default("UPCOMING")
  wardId      String
  ward        Ward     @relation(fields: [wardId], references: [id])
  createdById String
  createdAt   DateTime @default(now())
  resolutions Resolution[]
}

model Resolution {
  id           String     @id @default(uuid())
  text         String
  status       String     @default("PENDING")
  discussionId String
  discussion   Discussion @relation(fields: [discussionId], references: [id])
  createdAt    DateTime   @default(now())
}

model Group {
  id               String   @id @default(uuid())
  name             String
  leaderName       String
  meetingDay       String
  meetingFrequency String?
  members          String?
  memberCount      Int      @default(0)
  wardId           String
  ward             Ward     @relation(fields: [wardId], references: [id])
  createdAt        DateTime @default(now())
}
